# Copy to .env and edit. Only set what you actually use — every var is optional.

# Default provider: lmstudio, ollama, llamacpp, openrouter, grok, openai, groq,
# together, deepinfra, mistral, or any custom name you configure below.
LLM_PROVIDER=lmstudio

# Default model id, exactly as the chosen provider names it.
LLM_MODEL=your-local-model-id

# Request timeout in seconds (a big local model on modest hardware can be slow).
LLM_TIMEOUT=300

# --- Per-provider overrides ---------------------------------------------------
# Point LM Studio at a LAN host instead of localhost (run Claude and LM Studio on
# different machines):
# LMSTUDIO_BASE_URL=http://192.168.1.50:1234/v1

# Hosted providers — set the key for whichever you use:
# OPENROUTER_API_KEY=sk-or-...
# XAI_API_KEY=xai-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk-...
# TOGETHER_API_KEY=...

# Optional OpenRouter ranking headers:
# OPENROUTER_REFERER=https://your-site.example
# OPENROUTER_TITLE=mcp-llm-offload

# --- Custom provider example --------------------------------------------------
# Any OpenAI-compatible endpoint works. Pick a name (e.g. "foo"), then call tools
# with provider="foo":
# FOO_BASE_URL=https://api.example.com/v1
# FOO_API_KEY=...
